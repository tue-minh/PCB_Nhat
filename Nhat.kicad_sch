	(text "=========== MPU6050 ===========\nAD0: 				Select chip address (0: 0x68, 1: 0x69-can change)\nINT: 				Interrupt signal\nAUX_CL, AUX_DA: 	External I2C pin function (for external communication)\nCLKIN: 				Input Clock\nFSYNC: 				Sync performance to other hardware in system\nREGOUT: 			3V3 out integrated LDO\nCPOUT: 				Add cap 2.2nf to gnd"
		(exclude_from_sim no)
		(at 298.196 18.034 0)
		(effects
			(font
				(face "Times New Roman")
				(size 2.54 2.54)
				(bold yes)
			)
			(justify left)
		)
		(uuid "a5173a41-3f30-43ad-85a3-04fb57b52d8f")
	)
